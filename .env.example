DISCORD_TOKEN=your_token_here
GUILD_ID=your_main_guild_id_here
FRIEND_GUILD_ID=your_friend_guild_id_here       # optional — enables friend server mode
WHITELIST_USER_IDS=123456789,987654321          # optional — comma-separated IDs whose original message is deleted on main server

# Performance tuning
MAX_CONCURRENT_JOBS=8                           # max simultaneous download+compress jobs
YT_DLP_FRAGMENTS=16                             # parallel fragment downloads per video
USE_NVENC=1                                     # use NVIDIA hardware encoding (requires NVIDIA GPU)
USE_HEVC=0                                      # use HEVC/H.265 instead of H.264 (better compression, less compatible)
USE_HWACCEL=1                                   # GPU-accelerated video decoding (requires USE_NVENC=1)
NVENC_MAX_SESSIONS=3                            # max concurrent GPU encode sessions (consumer GPUs: 3-5)
PROCESS_NICE=10                                 # nice level for ffmpeg (0=normal, 19=lowest priority)
FFMPEG_TIMEOUT=300                              # ffmpeg process timeout in seconds
USE_ARIA2C=1                                    # use aria2c for faster downloads (auto-detected)
PERSISTENT_CACHE=1                              # persist Reddit URL caches to SQLite across restarts
YOUTUBE_QUALITY=1080                            # initial YouTube resolution: 360, 480, 720, or 1080. Change live with the /quality admin command. 360p is fastest; higher is sharper but slower.
